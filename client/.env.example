# Base URL of the deployed AbacusDetect backend.
#
# REQUIRED for the packaged Android app so it can save and load results from the
# central health record (the app's WebView is not served by the backend). Set it
# to your published URL before running `npm run build && npx cap sync android`.
#
# Leave it empty for local web/desktop development — the web app talks to its
# own origin with relative URLs.
#
# Example:
# VITE_API_BASE_URL=https://your-app.replit.app
VITE_API_BASE_URL=
