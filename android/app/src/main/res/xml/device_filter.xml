<?xml version="1.0" encoding="utf-8"?>
<!--
  USB vendor IDs (decimal) of common USB-serial bridge chips. When a matching
  device is attached, Android brings AbacusDetect to the front and can remember
  the USB permission for that device.

  If the MicroNow reader is not detected, plug it into a computer, note its
  vendor ID (VID) and product ID (PID), and add a line here. VID/PID are decimal
  in this file (e.g. hex 0x0403 -> 1027). You can narrow a rule to one device
  with: <usb-device vendor-id="1027" product-id="24577" />
-->
<resources>
    <!-- FTDI (0x0403) -->
    <usb-device vendor-id="1027" />
    <!-- Silicon Labs CP210x (0x10C4) -->
    <usb-device vendor-id="4292" />
    <!-- Prolific PL2303 (0x067B) -->
    <usb-device vendor-id="1659" />
    <!-- QinHeng CH34x / CH9102 (0x1A86) -->
    <usb-device vendor-id="6790" />
    <!-- Arduino (0x2341) -->
    <usb-device vendor-id="9025" />
    <!-- Arduino SA (0x2A03) -->
    <usb-device vendor-id="10755" />
    <!-- Espressif (0x303A) -->
    <usb-device vendor-id="12346" />
</resources>
